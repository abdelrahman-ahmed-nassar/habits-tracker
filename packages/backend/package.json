{
  "name": "@ultimate-habits-tracker/backend",
  "version": "1.0.0",
  "description": "Backend API for Ultimate Habits Tracker",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only --env-file=sample.env src/server.ts",
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:server": "jest server",
    "test:middlewares": "jest middlewares",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint",
    "check:strict": "tsc --noEmit --strict --strictNullChecks --strictFunctionTypes --strictBindCallApply --strictPropertyInitialization --noImplicitAny --noImplicitThis",
    "find-ts-errors": "node scripts/find-ts-errors.js",
    "check:all": "node scripts/complete-check.js",
    "validate": "npm run check && npm run test",
    "init-data": "node scripts/initializeData.js",
    "backup": "ts-node scripts/createFullBackup.ts",
    "backup:clean": "ts-node scripts/cleanupOldBackups.ts"
  },
  "dependencies": {
    "archiver": "^5.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
